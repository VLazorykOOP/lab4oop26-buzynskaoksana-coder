class CountryCapital {
private:
    char** countries;
    char** capitals;
    int    count;
    int    capacity;
    int    codeError;

    static char* copyStr(const char* src) {
        if(!src) return nullptr;
        char* d=new char[strlen(src)+1];
        strcpy(d,src); return d;
    }
    void freeAll() {
        for(int i=0;i<count;i++){delete[] countries[i];delete[] capitals[i];}
        delete[] countries; delete[] capitals;
    }

public:
    CountryCapital() : count(0), capacity(10), codeError(0) {
        countries=new char*[capacity]; capitals=new char*[capacity];
    }
    CountryCapital(int cap) : count(0), capacity(cap), codeError(0) {
        countries=new char*[capacity]; capitals=new char*[capacity];
    }
    CountryCapital(const CountryCapital& o)
        : count(o.count), capacity(o.capacity), codeError(o.codeError) {
        countries=new char*[capacity]; capitals=new char*[capacity];
        for(int i=0;i<count;i++){
            countries[i]=copyStr(o.countries[i]);
            capitals[i] =copyStr(o.capitals[i]);
        }
    }
    ~CountryCapital() { freeAll(); }

    CountryCapital& operator=(const CountryCapital& o) {
        if(this==&o) return *this;
        freeAll();
        count=o.count; capacity=o.capacity; codeError=o.codeError;
        countries=new char*[capacity]; capitals=new char*[capacity];
        for(int i=0;i<count;i++){
            countries[i]=copyStr(o.countries[i]);
            capitals[i] =copyStr(o.capitals[i]);
        }
        return *this;
    }

    int  getCount()     const { return count; }
    int  getCodeError() const { return codeError; }
    void clearError()         { codeError=0; }

    bool add(const char* country, const char* capital) {
        if(count>=capacity){codeError=-2;return false;}
        countries[count]=copyStr(country);
        capitals[count] =copyStr(capital);
        count++; return true;
    }

    void fillDefault() {
        const char* d[][2]={
            {"Ukraine","Kyiv"},{"France","Paris"},{"Germany","Berlin"},
            {"Japan","Tokyo"},{"USA","Washington"},{"UK","London"},
            {"Spain","Madrid"},{"Italy","Rome"},{"Poland","Warsaw"},{"Canada","Ottawa"}
        };
        for(int i=0;i<10&&count<capacity;i++) add(d[i][0],d[i][1]);
    }

    const char* operator[](const char* country) {
        for(int i=0;i<count;i++)
            if(strcmp(countries[i],country)==0) return capitals[i];
        codeError=-1; return nullptr;
    }
    const char* operator()(const char* capital) {
        for(int i=0;i<count;i++)
            if(strcmp(capitals[i],capital)==0) return countries[i];
        codeError=-1; return nullptr;
    }

    bool saveToFile(const string& f) const {
        ofstream fo(f); if(!fo.is_open()) return false;
        fo<<count<<"\n";
        for(int i=0;i<count;i++) fo<<countries[i]<<"\n"<<capitals[i]<<"\n";
        return true;
    }
    bool loadFromFile(const string& f) {
        ifstream fi(f); if(!fi.is_open()) return false;
        for(int i=0;i<count;i++){delete[] countries[i];delete[] capitals[i];}
        count=0;
        int n; fi>>n; fi.ignore();
        for(int i=0;i<n&&i<capacity;i++){
            char b1[256],b2[256];
            fi.getline(b1,256); fi.getline(b2,256);
            add(b1,b2);
        }
        return true;
    }

    friend ostream& operator<<(ostream& os, const CountryCapital& cc);
    friend istream& operator>>(istream& is, CountryCapital& cc);
};

ostream& operator<<(ostream& os, const CountryCapital& cc) {
    os<<"+---------------------+---------------------+\n";
    os<<"| Country             | Capital             |\n";
    os<<"+---------------------+---------------------+\n";
    for(int i=0;i<cc.count;i++){
        char c1[21],c2[21];
        snprintf(c1,sizeof(c1),"%-19s",cc.countries[i]);
        snprintf(c2,sizeof(c2),"%-19s",cc.capitals[i]);
        os<<"| "<<c1<<" | "<<c2<<" |\n";
    }
    os<<"+---------------------+---------------------+\n";
    os<<"Total: "<<cc.count<<" pairs\n";
    return os;
}
istream& operator>>(istream& is, CountryCapital& cc) {
    int n; cout<<"How many pairs? "; is>>n; is.ignore();
    for(int i=0;i<n;i++){
        char co[256],ca[256];
        cout<<"  Country "<<(i+1)<<": "; is.getline(co,256);
        cout<<"  Capital "<<(i+1)<<": "; is.getline(ca,256);
        cc.add(co,ca);
    }
    return is;
}

