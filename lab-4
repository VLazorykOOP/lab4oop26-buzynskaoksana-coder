void runTask3() {
    cout << "\n=== TASK 3: MatrixFload ===\n";

    cout << "\n-- Constructors --\n";
    MatrixFload m0;
    MatrixFload m1(3);
    MatrixFload m2(2, 3);
    MatrixFload m3(2, 3, 4.0f);
    MatrixFload m4(m3);
    cout << "m0 (empty):\n"        << m0;
    cout << "m1 (identity 3x3):\n" << m1;
    cout << "m2 (zeros 2x3):\n"    << m2;
    cout << "m3 (2x3, val=4):\n"   << m3;
    cout << "m4 (copy of m3):\n"   << m4;

    cout << "\n-- Unary operators --\n";
    MatrixFload U(2, 3);
    cout << "Enter U (2x3):\n"; cin >> U;
    cout << "U:\n"     << U;
    cout << "++U:\n"   << (++U);
    cout << "U--:\n"   << (U--);
    cout << "U now:\n" << U;
    cout << "!U: "     << (!U ? "true" : "false") << "\n";
    cout << "-U:\n"    << (-U);

    cout << "\n-- Enter matrices A, B, C (2x3) --\n";
    MatrixFload A(2,3), B(2,3), C(2,3);
    cout << "Enter A (2x3):\n"; cin >> A;
    cout << "Enter B (2x3):\n"; cin >> B;
    cout << "Enter C (2x3):\n"; cin >> C;
    cout << "A:\n" << A;
    cout << "B:\n" << B;
    cout << "C:\n" << C;

    cout << "\n-- Expression: (A+B)*2.0 - C/1.5 + A%3 --\n";
    MatrixFload r1 = (A + B) * 2.0f - C / 1.5f + A % 3;
    cout << "Result:\n" << r1;

    cout << "\n-- Compound assignment --\n";
    MatrixFload P(A);
    cout << "P = A:\n" << P;
    P += B;    cout << "P += B:\n"   << P;
    P -= C;    cout << "P -= C:\n"   << P;
    P *= 0.5f; cout << "P *= 0.5:\n" << P;
    P /= 2.0f; cout << "P /= 2.0:\n" << P;
    P %= 3;    cout << "P %= 3:\n"   << P;

    cout << "\n-- Expression: (++Q)*vec - (-A)/1.5 + B --\n";
    VectorFloat vec(3);
    cout << "Enter vec (3 elements):\n"; cin >> vec;
    MatrixFload Q(A);
    MatrixFload r3 = (++Q) * vec - (-A) / 1.5f + B;
    cout << "vec: " << vec << "\n";
    cout << "Result:\n" << r3;

    cout << "\n-- Comparison --\n";
    cout << "A > B:  " << (A >  B ? "true" : "false") << "\n";
    cout << "A >= B: " << (A >= B ? "true" : "false") << "\n";
    cout << "A < C:  " << (A <  C ? "true" : "false") << "\n";
    cout << "A <= C: " << (A <= C ? "true" : "false") << "\n";
    cout << "A == A: " << (A == A ? "true" : "false") << "\n";
    cout << "A != B: " << (A != B ? "true" : "false") << "\n";

    cout << "\n-- Instance counter --\n";
    cout << "MatrixFload instances: " << MatrixFload::getNumMatrix() << "\n";
}

