class VectorFloat {
public:
    float* data;
    int    size;
    int    codeError;
    static int instanceCount;

    VectorFloat() : size(1), codeError(0) {
        data    = new float[1];
        data[0] = 0.0f;
        instanceCount++;
    }
    VectorFloat(int n) : size(n), codeError(0) {
        data = new float[size];
        for (int i = 0; i < size; i++) data[i] = 0.0f;
        instanceCount++;
    }
    VectorFloat(int n, float value) : size(n), codeError(0) {
        data = new float[size];
        for (int i = 0; i < size; i++) data[i] = value;
        instanceCount++;
    }
    VectorFloat(const VectorFloat& other) : size(other.size), codeError(other.codeError) {
        data = new float[size];
        for (int i = 0; i < size; i++) data[i] = other.data[i];
        instanceCount++;
    }
    ~VectorFloat() {
        delete[] data;
        instanceCount--;
    }

    int getSize()      const { return size; }
    int getCodeError() const { return codeError; }
    static int getInstanceCount() { return instanceCount; }

    VectorFloat& operator=(const VectorFloat& other) {
        if (this == &other) return *this;
        delete[] data;
        size      = other.size;
        codeError = other.codeError;
        data      = new float[size];
        for (int i = 0; i < size; i++) data[i] = other.data[i];
        return *this;
    }

    float& operator[](int index) {
        if (index < 0 || index >= size) { codeError = -1; return data[size-1]; }
        return data[index];
    }
    float operator[](int index) const {
        if (index < 0 || index >= size) return data[size-1];
        return data[index];
    }

    VectorFloat& operator++()    { for(int i=0;i<size;i++) data[i]+=1.0f; return *this; }
    VectorFloat  operator++(int) { VectorFloat t(*this); for(int i=0;i<size;i++) data[i]+=1.0f; return t; }
    VectorFloat& operator--()    { for(int i=0;i<size;i++) data[i]-=1.0f; return *this; }
    VectorFloat  operator--(int) { VectorFloat t(*this); for(int i=0;i<size;i++) data[i]-=1.0f; return t; }

    bool        operator!() const { return size != 0; }
    VectorFloat operator-() const {
        VectorFloat r(size);
        for(int i=0;i<size;i++) r.data[i]=-data[i];
        return r;
    }

    VectorFloat& operator+=(const VectorFloat& o) {
        for(int i=0;i<size&&i<o.size;i++) data[i]+=o.data[i]; return *this;
    }
    VectorFloat& operator-=(const VectorFloat& o) {
        for(int i=0;i<size&&i<o.size;i++) data[i]-=o.data[i]; return *this;
    }
    VectorFloat& operator*=(float s) { for(int i=0;i<size;i++) data[i]*=s; return *this; }
    VectorFloat& operator/=(float s) {
        if(s==0.0f){codeError=-2;return *this;}
        for(int i=0;i<size;i++) data[i]/=s; return *this;
    }
    VectorFloat& operator%=(float s) {
        if(s==0.0f){codeError=-2;return *this;}
        for(int i=0;i<size;i++) data[i]=data[i]-static_cast<int>(data[i]/s)*s;
        return *this;
    }

    friend VectorFloat operator+(const VectorFloat& a, const VectorFloat& b);
    friend VectorFloat operator-(const VectorFloat& a, const VectorFloat& b);
    friend VectorFloat operator*(const VectorFloat& v, float s);
    friend VectorFloat operator*(float s, const VectorFloat& v);
    friend VectorFloat operator/(const VectorFloat& v, float s);
    friend VectorFloat operator%(const VectorFloat& v, float s);

    friend bool operator==(const VectorFloat& a, const VectorFloat& b);
    friend bool operator!=(const VectorFloat& a, const VectorFloat& b);
    friend bool operator> (const VectorFloat& a, const VectorFloat& b);
    friend bool operator>=(const VectorFloat& a, const VectorFloat& b);
    friend bool operator< (const VectorFloat& a, const VectorFloat& b);
    friend bool operator<=(const VectorFloat& a, const VectorFloat& b);

    friend ostream& operator<<(ostream& os, const VectorFloat& v);
    friend istream& operator>>(istream& is, VectorFloat& v);
};

int VectorFloat::instanceCount = 0;

static float vecSum(const VectorFloat& v) {
    float s=0; for(int i=0;i<v.size;i++) s+=v.data[i]; return s;
}

VectorFloat operator+(const VectorFloat& a, const VectorFloat& b) {
    int n=a.size<b.size?a.size:b.size; VectorFloat r(n);
    for(int i=0;i<n;i++) r.data[i]=a.data[i]+b.data[i]; return r;
}
VectorFloat operator-(const VectorFloat& a, const VectorFloat& b) {
    int n=a.size<b.size?a.size:b.size; VectorFloat r(n);
    for(int i=0;i<n;i++) r.data[i]=a.data[i]-b.data[i]; return r;
}
VectorFloat operator*(const VectorFloat& v, float s) {
    VectorFloat r(v.size); for(int i=0;i<v.size;i++) r.data[i]=v.data[i]*s; return r;
}
VectorFloat operator*(float s, const VectorFloat& v) { return v*s; }
VectorFloat operator/(const VectorFloat& v, float s) {
    VectorFloat r(v.size);
    if(s==0.0f){r.codeError=-2;return r;}
    for(int i=0;i<v.size;i++) r.data[i]=v.data[i]/s; return r;
}
VectorFloat operator%(const VectorFloat& v, float s) {
    VectorFloat r(v.size);
    if(s==0.0f){r.codeError=-2;return r;}
    for(int i=0;i<v.size;i++) r.data[i]=v.data[i]-static_cast<int>(v.data[i]/s)*s;
    return r;
}

bool operator==(const VectorFloat& a, const VectorFloat& b) {
    if(a.size!=b.size) return false;
    for(int i=0;i<a.size;i++) if(a.data[i]!=b.data[i]) return false;
    return true;
}
bool operator!=(const VectorFloat& a, const VectorFloat& b) { return !(a==b); }
bool operator> (const VectorFloat& a, const VectorFloat& b) { return vecSum(a)> vecSum(b); }
bool operator>=(const VectorFloat& a, const VectorFloat& b) { return vecSum(a)>=vecSum(b); }
bool operator< (const VectorFloat& a, const VectorFloat& b) { return vecSum(a)< vecSum(b); }
bool operator<=(const VectorFloat& a, const VectorFloat& b) { return vecSum(a)<=vecSum(b); }

ostream& operator<<(ostream& os, const VectorFloat& v) {
    os << "[ ";
    for(int i=0;i<v.size;i++) os<<v.data[i]<<(i<v.size-1?", ":" ");
    os << "]"; return os;
}
istream& operator>>(istream& is, VectorFloat& v) {
    for(int i=0;i<v.size;i++) { cout<<"  ["<<i<<"]: "; is>>v.data[i]; }
    return is;
}

