class MatrixFload {
private:
    float** data;
    int     n, m;
    int     codeError;
    static int num_matrix;

    void allocate(int rows, int cols) {
        data = new float*[rows];
        for(int i=0;i<rows;i++){
            data[i]=new float[cols];
            for(int j=0;j<cols;j++) data[i][j]=0.0f;
        }
    }
    void freeAll() {
        for(int i=0;i<n;i++) delete[] data[i];
        delete[] data; data=nullptr;
    }

public:
    MatrixFload() : data(nullptr), n(0), m(0), codeError(0) { num_matrix++; }

    MatrixFload(int sz) : n(sz), m(sz), codeError(0) {
        allocate(n,m);
        for(int i=0;i<n;i++) data[i][i]=1.0f;
        num_matrix++;
    }
    MatrixFload(int rows, int cols) : n(rows), m(cols), codeError(0) {
        allocate(n,m); num_matrix++;
    }
    MatrixFload(int rows, int cols, float val) : n(rows), m(cols), codeError(0) {
        allocate(n,m);
        for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]=val;
        num_matrix++;
    }
    MatrixFload(const MatrixFload& o) : n(o.n), m(o.m), codeError(o.codeError) {
        allocate(n,m);
        for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]=o.data[i][j];
        num_matrix++;
    }
    ~MatrixFload() { if(data) freeAll(); num_matrix--; }

    int getRows()      const { return n; }
    int getCols()      const { return m; }
    int getCodeError() const { return codeError; }
    static int getNumMatrix() { return num_matrix; }

    float& at(int i,int j)       { return data[i][j]; }
    float  at(int i,int j) const { return data[i][j]; }

    MatrixFload& operator=(const MatrixFload& o) {
        if(this==&o) return *this;
        freeAll(); n=o.n; m=o.m; codeError=o.codeError;
        allocate(n,m);
        for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]=o.data[i][j];
        return *this;
    }

    MatrixFload& operator++()    { for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]+=1.0f; return *this; }
    MatrixFload  operator++(int) { MatrixFload t(*this); for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]+=1.0f; return t; }
    MatrixFload& operator--()    { for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]-=1.0f; return *this; }
    MatrixFload  operator--(int) { MatrixFload t(*this); for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]-=1.0f; return t; }

    bool        operator!() const { return n!=0&&m!=0; }
    MatrixFload operator-() const {
        MatrixFload r(n,m);
        for(int i=0;i<n;i++) for(int j=0;j<m;j++) r.data[i][j]=-data[i][j];
        return r;
    }

    MatrixFload& operator+=(const MatrixFload& o) {
        for(int i=0;i<n&&i<o.n;i++) for(int j=0;j<m&&j<o.m;j++) data[i][j]+=o.data[i][j];
        return *this;
    }
    MatrixFload& operator+=(float s)  { for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]+=s; return *this; }
    MatrixFload& operator+=(double s) { return *this+=static_cast<float>(s); }
    MatrixFload& operator-=(const MatrixFload& o) {
        for(int i=0;i<n&&i<o.n;i++) for(int j=0;j<m&&j<o.m;j++) data[i][j]-=o.data[i][j];
        return *this;
    }
    MatrixFload& operator-=(float s)  { for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]-=s; return *this; }
    MatrixFload& operator-=(double s) { return *this-=static_cast<float>(s); }
    MatrixFload& operator*=(const MatrixFload& o) {
        for(int i=0;i<n&&i<o.n;i++) for(int j=0;j<m&&j<o.m;j++) data[i][j]*=o.data[i][j];
        return *this;
    }
    MatrixFload& operator*=(const VectorFloat& v) {
        for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]*=(j<v.size?v.data[j]:1.0f);
        return *this;
    }
    MatrixFload& operator*=(float s)  { for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]*=s; return *this; }
    MatrixFload& operator*=(double s) { return *this*=static_cast<float>(s); }
    MatrixFload& operator/=(int s) {
        if(s==0){codeError=-2;return *this;}
        for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]/=static_cast<float>(s);
        return *this;
    }
    MatrixFload& operator/=(float s) {
        if(s==0.0f){codeError=-2;return *this;}
        for(int i=0;i<n;i++) for(int j=0;j<m;j++) data[i][j]/=s;
        return *this;
    }
    MatrixFload& operator/=(double s) { return *this/=static_cast<float>(s); }
    MatrixFload& operator%=(int s) {
        if(s==0){codeError=-2;return *this;}
        for(int i=0;i<n;i++) for(int j=0;j<m;j++){float& v=data[i][j];v=v-static_cast<int>(v/s)*s;}
        return *this;
    }
    MatrixFload& operator%=(float s) {
        if(s==0.0f){codeError=-2;return *this;}
        for(int i=0;i<n;i++) for(int j=0;j<m;j++){float& v=data[i][j];v=v-static_cast<int>(v/s)*s;}
        return *this;
    }

    friend MatrixFload operator+(const MatrixFload& a, const MatrixFload& b);
    friend MatrixFload operator+(const MatrixFload& a, float s);
    friend MatrixFload operator-(const MatrixFload& a, const MatrixFload& b);
    friend MatrixFload operator-(const MatrixFload& a, float s);
    friend MatrixFload operator-(const MatrixFload& a, double s);
    friend MatrixFload operator*(const MatrixFload& a, const MatrixFload& b);
    friend MatrixFload operator*(const MatrixFload& a, const VectorFloat& v);
    friend MatrixFload operator*(const MatrixFload& a, float s);
    friend MatrixFload operator*(float s, const MatrixFload& a);
    friend MatrixFload operator*(const MatrixFload& a, double s);
    friend MatrixFload operator/(const MatrixFload& a, int s);
    friend MatrixFload operator/(const MatrixFload& a, float s);
    friend MatrixFload operator/(const MatrixFload& a, double s);
    friend MatrixFload operator%(const MatrixFload& a, int s);

    friend bool operator==(const MatrixFload& a, const MatrixFload& b);
    friend bool operator!=(const MatrixFload& a, const MatrixFload& b);
    friend bool operator> (const MatrixFload& a, const MatrixFload& b);
    friend bool operator>=(const MatrixFload& a, const MatrixFload& b);
    friend bool operator< (const MatrixFload& a, const MatrixFload& b);
    friend bool operator<=(const MatrixFload& a, const MatrixFload& b);

    friend ostream& operator<<(ostream& os, const MatrixFload& m);
    friend istream& operator>>(istream& is, MatrixFload& m);
    friend float matSum(const MatrixFload& m);
};

int MatrixFload::num_matrix = 0;

float matSum(const MatrixFload& mat) {
    float s=0;
    for(int i=0;i<mat.n;i++) for(int j=0;j<mat.m;j++) s+=mat.data[i][j];
    return s;
}

MatrixFload operator+(const MatrixFload& a, const MatrixFload& b) { MatrixFload r(a); r+=b; return r; }
MatrixFload operator+(const MatrixFload& a, float s)              { MatrixFload r(a); r+=s; return r; }
MatrixFload operator-(const MatrixFload& a, const MatrixFload& b) { MatrixFload r(a); r-=b; return r; }
MatrixFload operator-(const MatrixFload& a, float s)              { MatrixFload r(a); r-=s; return r; }
MatrixFload operator-(const MatrixFload& a, double s)             { MatrixFload r(a); r-=static_cast<float>(s); return r; }
MatrixFload operator*(const MatrixFload& a, const MatrixFload& b) { MatrixFload r(a); r*=b; return r; }
MatrixFload operator*(const MatrixFload& a, const VectorFloat& v) { MatrixFload r(a); r*=v; return r; }
MatrixFload operator*(const MatrixFload& a, float s)              { MatrixFload r(a); r*=s; return r; }
MatrixFload operator*(float s, const MatrixFload& a)              { return a*s; }
MatrixFload operator*(const MatrixFload& a, double s)             { return a*static_cast<float>(s); }
MatrixFload operator/(const MatrixFload& a, int s)                { MatrixFload r(a); r/=s; return r; }
MatrixFload operator/(const MatrixFload& a, float s)              { MatrixFload r(a); r/=s; return r; }
MatrixFload operator/(const MatrixFload& a, double s)             { MatrixFload r(a); r/=static_cast<float>(s); return r; }
MatrixFload operator%(const MatrixFload& a, int s)                { MatrixFload r(a); r%=s; return r; }

bool operator==(const MatrixFload& a, const MatrixFload& b) {
    if(a.n!=b.n||a.m!=b.m) return false;
    for(int i=0;i<a.n;i++) for(int j=0;j<a.m;j++) if(a.data[i][j]!=b.data[i][j]) return false;
    return true;
}
bool operator!=(const MatrixFload& a, const MatrixFload& b) { return !(a==b); }
bool operator> (const MatrixFload& a, const MatrixFload& b) { return matSum(a)> matSum(b); }
bool operator>=(const MatrixFload& a, const MatrixFload& b) { return matSum(a)>=matSum(b); }
bool operator< (const MatrixFload& a, const MatrixFload& b) { return matSum(a)< matSum(b); }
bool operator<=(const MatrixFload& a, const MatrixFload& b) { return matSum(a)<=matSum(b); }

ostream& operator<<(ostream& os, const MatrixFload& mat) {
    if(mat.n==0||mat.m==0){ os<<"(empty matrix)\n"; return os; }
    os<<"[\n";
    for(int i=0;i<mat.n;i++){
        os<<"  ";
        for(int j=0;j<mat.m;j++){
            char buf[16]; snprintf(buf,sizeof(buf),"%7.2f",mat.data[i][j]);
            os<<buf<<(j<mat.m-1?"  ":"");
        }
        os<<"\n";
    }
    os<<"] ("<<mat.n<<"x"<<mat.m<<", err="<<mat.codeError<<")\n";
    return os;
}
istream& operator>>(istream& is, MatrixFload& mat) {
    for(int i=0;i<mat.n;i++){
        cout<<"  Row "<<i<<": ";
        for(int j=0;j<mat.m;j++) is>>mat.data[i][j];
    }
    return is;
}

