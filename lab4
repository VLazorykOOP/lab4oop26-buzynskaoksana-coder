void task2() {
    std::cout << "\n============================================\n";
    std::cout << "  TASK 2  |  CountryCapital\n";
    std::cout << "============================================\n";

    auto search = [](CountryCapital& c, const char* key, bool byCountry) {
        if (byCountry) {
            const char* r = c[key];
            if (r) std::cout << "  \"" << key << "\"  ->  capital: \"" << r << "\"\n";
            else   std::cout << "  \"" << key << "\"  ->  not found! err=" << c.getErrorCode() << "\n";
            c.clearError();
        } else {
            const char* r = c(key);
            if (r) std::cout << "  capital \"" << key << "\"  ->  country: \"" << r << "\"\n";
            else   std::cout << "  capital \"" << key << "\"  ->  not found! err=" << c.getErrorCode() << "\n";
            c.clearError();
        }
    };

    section("Choose input method for country-capital pairs");
    std::cout << "  1 = Enter manually\n";
    std::cout << "  2 = Use preset data (Ukraine/Kyiv, France/Paris, Germany/Berlin,\n";
    std::cout << "      Japan/Tokyo, USA/Washington, UK/London,\n";
    std::cout << "      Spain/Madrid, Italy/Rome, Poland/Warsaw, Canada/Ottawa)\n";
    std::cout << "Your choice: ";
    int inputChoice; std::cin >> inputChoice; std::cin.ignore();

    CountryCapital cc(20);
    if (inputChoice == 2) {
        cc.fillDefault();
        std::cout << "\n  Preset data loaded:\n" << cc;
    } else {
        std::cin >> cc;
        std::cout << "  Your data:\n" << cc;
    }

    section("operator[]  search capital by country");
    char buf[256];
    std::cout << "Enter country name to search: ";
    std::cin.getline(buf, 256);
    search(cc, buf, true);

    std::cout << "Enter another country (to test not found): ";
    std::cin.getline(buf, 256);
    search(cc, buf, true);

    section("operator()  —  search country by capital");
    std::cout << "Enter capital name to search: ";
    std::cin.getline(buf, 256);
    search(cc, buf, false);

    std::cout << "Enter another capital (to test not found): ";
    std::cin.getline(buf, 256);
    search(cc, buf, false);

    section("Add new pair");
    char co[256], ca[256];
    std::cout << "Enter new country: "; std::cin.getline(co, 256);
    std::cout << "Enter new capital: "; std::cin.getline(ca, 256);
    cc.add(co, ca);
    std::cout << "Updated table:\n" << cc;

    section("Save to file & load");
    cc.saveToFile("countries.txt");
    CountryCapital cc2(20);
    cc2.loadFromFile("countries.txt");
    std::cout << "Loaded from file:\n" << cc2;

    section("Copy constructor");
    CountryCapital cc3(cc2);
    std::cout << "Enter country to add to copy: "; std::cin.getline(co, 256);
    std::cout << "Enter its capital: "; std::cin.getline(ca, 256);
    cc3.add(co, ca);
    std::cout << "cc3 (copy + new pair):\n" << cc3;
    std::cout << "cc2 (original, unchanged):\n" << cc2;
}


